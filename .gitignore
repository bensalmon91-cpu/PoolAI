# PoolAIssistant Project - Root .gitignore

# ===== Environment & Secrets =====
.env
.env.*
*.env.local
credentials.json
secrets.json
*.pem
*.key

# ===== Python =====
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/

# ===== Node.js =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# ===== React Native / Mobile =====
# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/
*.xcworkspace
!*.xcworkspace/contents.xcworkspacedata
*.xcuserstate
ios/build/

# Android
android/.gradle/
android/app/build/
android/build/
*.apk
*.aab
*.keystore
!debug.keystore
local.properties

# Metro bundler
.metro-health-check*

# ===== Databases (large files) =====
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# ===== Logs =====
*.log
logs/
*.log.*

# ===== IDE & Editor =====
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# ===== OS Files =====
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db
nul

# ===== Temporary Files =====
*.tmp
*.temp
temp_*/
.cache/
*.bak
*.orig

# ===== Archives (keep in releases only) =====
# Uncomment if you don't want update archives in repo
# *.tar.gz
# *.zip

# ===== Project-Specific =====
# Virtual environments stored outside standard names
brain/

# Backup directories (use external backup solution)
backups/

# Output directories (generated data)
output/

# Pi clone images (too large for git)
pi-clone/

# Data directory (large datasets)
data/

# Test units (large test data)
test_units/

# Data sync chunks (generated)
# data/chunks/*.db
# !data/chunks/*.db.gz
