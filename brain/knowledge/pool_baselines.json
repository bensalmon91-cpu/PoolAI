  "chemistry_relationships": {
    "_description": "Established relationships between ORP, Chlorine, and pH based on water chemistry",
    "orp_chlorine": {
      "relationship": "positive_proportional",
      "expected_correlation_range": [
        0.5,
        0.75
      ],
      "formula": "ORP = slope * Chlorine + intercept",
      "typical_slope_range": [
        35,
        55
      ],
      "slope_unit": "mV per mg/L",
      "explanation": "Each 1 mg/L increase in chlorine should increase ORP by 35-55 mV",
      "response_time_typical_minutes": [
        0,
        30
      ],
      "warning_if_correlation_below": 0.4,
      "warning_if_slope_below": 20
    },
    "orp_ph": {
      "relationship": "negative_proportional",
      "expected_correlation_range": [
        -0.4,
        -0.15
      ],
      "formula": "ORP change = slope * pH change",
      "typical_slope_range": [
        -80,
        -50
      ],
      "slope_unit": "mV per pH unit",
      "explanation": "Each 0.1 pH increase reduces ORP by 5-8 mV due to HOCl/OCl- equilibrium shift",
      "response_time_typical_minutes": [
        0,
        5
      ],
      "warning_if_correlation_positive": true
    },
    "chlorine_ph": {
      "relationship": "typically_negative",
      "expected_correlation_range": [
        -0.8,
        -0.2
      ],
      "explanation": "Control system balancing - when one is dosed, the other often needs adjustment",
      "notes": "Strong negative correlation indicates active control. Weak correlation may indicate manual dosing."
    }
  },
