  "deviation_detection": {
    "_description": "Rules for detecting when current readings deviate from established baselines",
    "methods": {
      "zscore": {
        "formula": "z = (current_value - baseline_mean) / baseline_std",
        "warning_threshold": 2.5,
        "alarm_threshold": 3.5
      },
      "percentile": {
        "warning_if_below_p5_or_above_p95": true,
        "alarm_if_below_p1_or_above_p99": true
      },
      "correlation_shift": {
        "description": "Compare current correlation to baseline correlation",
        "warning_if_difference_exceeds": 0.2,
        "alarm_if_difference_exceeds": 0.35
      },
      "slope_shift": {
        "description": "Compare current ORP-Chlorine slope to baseline",
        "warning_if_change_percent_exceeds": 30,
        "alarm_if_change_percent_exceeds": 50
      },
      "response_time_degradation": {
        "description": "Compare current response time to baseline",
        "warning_if_exceeds_baseline_by_percent": 50,
        "alarm_if_exceeds_baseline_by_percent": 100
      }
    },
    "interpretation_guide": {
      "correlation_drop_chlorine_orp": [
        "Sensor fouling (ORP or chlorine probe)",
        "Air bubbles in sensor flow cell",
        "Chemical interference (high cyanuric acid, metals)",
        "Flow rate change past sensors"
      ],
      "slope_decrease_orp_chlorine": [
        "ORP sensor aging/drift",
        "Chlorine sensor calibration drift",
        "Water chemistry change (CYA, temperature)",
        "Increased organic load consuming chlorine"
      ],
      "response_time_increase": [
        "Pump wear/degradation",
        "Partially blocked dosing line",
        "Low chemical tank level",
        "Increased pool volume/dilution"
      ]
    }
  },
  "update_protocol": {
    "frequency": "Weekly recommended, daily minimum for new pools",
    "data_requirements": {
      "minimum_data_points": 1000,
      "minimum_time_span_hours": 24
    },
    "rolling_baseline": {
      "enabled": true,
      "lookback_days": 14,
      "description": "Baselines are updated using rolling 14-day windows to adapt to seasonal changes"
    },
    "stability_check": {
      "description": "Only update baseline if pool is in stable operation",
      "exclude_if": [
        "Pool was refilled within 48 hours",
        "Major maintenance performed",
        "Dosing system was offline",
        "More than 10% anomalies detected"
      ]
    }
  }
