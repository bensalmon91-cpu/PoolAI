# ========================================
# PoolAIssistant Deployment Configuration
# ========================================
# Copy this file to deploy_config.env and customize for your deployment

# Deployment target (full user@host format)
DEPLOY_TARGET=poolaissitant@10.0.30.80

# Or specify separately:
# DEPLOY_USER=poolaissitant
# DEPLOY_HOST=10.0.30.80

# Deployment path on Pi
# DEPLOY_PATH=/opt/PoolAIssistant/app

# Network configuration (optional, for setup_pi.sh)
# Set to 1 to skip network configuration entirely
SKIP_NETWORK_CONFIG=0

# Static LAN IP (optional, for setup_pi.sh)
# STATIC_LAN_IP=192.168.2.1/24

# SSH options
# SSH_KEY=/path/to/private/key
# SSH_PORT=22
