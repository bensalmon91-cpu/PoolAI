# If set, POOLS_JSON overrides UI-configured controllers (pooldash_settings.json).
# Logger expects a JSON object keyed by pool name.
POOLS_JSON={"Ezetrol-11":{"host":"192.168.2.11","port":502,"unit":1},"Ezetrol-12":{"host":"192.168.2.12","port":502,"unit":1}}
POOLDB=/opt/PoolAIssistant/data/pool_readings.sqlite3
MAINT_DB_PATH=/opt/PoolAIssistant/data/maintenance_logs.sqlite3
POOLDASH_SETTINGS_PATH=/opt/PoolAIssistant/data/pooldash_settings.json
# Backend connection (leave blank until backend is deployed)
# Example: BACKEND_URL=https://api.poolaissistant.example.com
BACKEND_URL=
# Example: BOOTSTRAP_SECRET=replace-with-strong-shared-secret
BOOTSTRAP_SECRET=
DEVICE_TOKEN_PATH=/opt/PoolAIssistant/data/device_token.json
DEVICE_MODEL=PoolAIssistant_v6
SOFTWARE_VERSION=PoolAIssistant v6.1.1
BACKEND_STATUS_PATH=/opt/PoolAIssistant/data/backend_status.json
UPLOAD_MODE=delta
UPLOAD_BATCH_SIZE=500
UPLOAD_STATE_PATH=/opt/PoolAIssistant/data/upload_state.json
UPDATE_CHANNEL=stable
UPDATE_STATUS_PATH=/opt/PoolAIssistant/data/update_status.json
UPDATE_DOWNLOAD_DIR=/opt/PoolAIssistant/updates
UPDATE_AUTO_APPLY=0

# REQUIRED for logger: use UI controllers list, or set POOLS_JSON as above.
